# Knowledge-Graph RAG Explorer — API config
# All values have sane defaults; the app runs fully OFFLINE with no keys.

# HTTP server
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*

# LLM provider: "mock" (default, deterministic, offline) | "baml" (needs keys + generated client)
LLM_PROVIDER=mock

# Where vectors/graph/documents JSON artifacts are persisted
DATA_DIR=./data

# Only required when LLM_PROVIDER=baml. ANTHROPIC_API_KEY (Claude) is the primary
# and the only key needed; OPENAI_API_KEY / MISTRAL_API_KEY are optional and
# enable the GPT-4o / Mistral fallback legs.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# MISTRAL_API_KEY=
