# ── Backend (apps/api) ───────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*
DATA_DIR=./data

# LLM provider: "mock" (default, fully offline) or "baml" (real models).
LLM_PROVIDER=mock

# Only needed when LLM_PROVIDER=baml. ANTHROPIC_API_KEY (Claude) is the primary
# and the only key required. OPENAI_API_KEY / MISTRAL_API_KEY are optional and
# activate the GPT-4o / Mistral fallback legs of BAML's Primary client.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ── Frontend (apps/web) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
