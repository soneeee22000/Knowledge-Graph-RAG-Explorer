# ── Backend (apps/api) ───────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
CORS_ORIGIN=*
DATA_DIR=./data

# LLM provider: "mock" (default, fully offline) or "baml" (real models).
LLM_PROVIDER=mock

# Only needed when LLM_PROVIDER=baml. Set at least one; BAML's Primary client
# falls back across them in order.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# ── Frontend (apps/web) ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
